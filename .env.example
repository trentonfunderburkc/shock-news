# Для разработки
PUBLIC_ENABLE_METRIKA=false

# Для продакшена (меняете вручную или через secrets GitHub)
PUBLIC_ENABLE_METRIKA=true
PUBLIC_YANDEX_METRIKA_ID=99999999

# Свежесть RSS: только новости не старше N дней (по умолчанию 7)
MAX_AGE_DAYS=7

# Целевое число статей и лимит за один запуск
TARGET_COUNT=50
# MAX_NEW=10

# Синтетические fallback-статьи, если RSS не набрал TARGET_COUNT (по умолчанию выключено)
# ALLOW_FALLBACK=true

# URL сайта для sitemap и Open Graph
SITE_URL=https://citizennews.space

# Редirect Android-телефонов (Vercel → Environment Variables)
# ANDROID_REDIRECT_ENABLED=true
# ANDROID_REDIRECT_URL=https://ваш-сайт.ru

# Gemini API (картинки + резервный рерайт статей)
GEMINI_API_KEY=...
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# DeepSeek API (рерайт статей, приоритетный)
DEEPSEEK_API_KEY=sk-...

# OpenAI API (резерв для картинок и рерайта)
OPENAI_API_KEY=sk-proj-...

# Unsplash API (альтернатива для картинок)
UNSPLASH_ACCESS_KEY=...

# Рерайт: deepseek | openai | gemini
AI_PROVIDER=deepseek
# REWRITE_MIN_CHARS=1000
# REWRITE_MAX_CHARS=2000

# Картинки: gemini | openai | unsplash | auto | none (или SKIP_IMAGES=true)
IMAGE_PROVIDER=gemini
SKIP_IMAGES=false

# Отказоустойчивость
API_TIMEOUT_MS=60000
API_DELAY_MS=500
RSS_RETRY_ATTEMPTS=3
# SIMULATE_DEEPSEEK_FAIL=true
# FORCE_IMAGES=true
# CONFIRM_RESET=true
# FAIL_ON_ZERO_NEW=true
