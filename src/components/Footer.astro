---
import { site, categoryUrl } from '../lib/site';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const { publisher } = site;
---

<footer class="mt-auto border-t-4 border-[#c41e3a] bg-[#111827] text-gray-300">
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <h3 class="font-headline text-lg font-bold text-white mb-3">{site.name}</h3>
        <p class="text-sm leading-relaxed text-gray-400">{site.description}</p>
        <p class="mt-3 text-xs text-gray-500">
          Материалы цитируются со ссылкой на первоисточник (ст. 1274 ГК РФ).
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">Рубрики</h3>
        <ul class="space-y-2 text-sm">
          {site.categories.map((cat) => (
            <li>
              <a href={categoryUrl(cat.slug, base)} class="hover:text-white transition-colors">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">Информация</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}about/`} class="hover:text-white transition-colors">О проекте</a></li>
          <li><a href={`${base}editorial/`} class="hover:text-white transition-colors">Редакционная политика</a></li>
          <li><a href={`${base}authors/`} class="hover:text-white transition-colors">Авторы</a></li>
          <li><a href={`${base}contacts/`} class="hover:text-white transition-colors">Контакты</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">Правовая информация</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${base}privacy/`} class="hover:text-white transition-colors">Политика конфиденциальности</a></li>
          <li><a href={`${base}terms/`} class="hover:text-white transition-colors">Пользовательское соглашение</a></li>
          <li><a href={`${base}cookies/`} class="hover:text-white transition-colors">Политика cookies</a></li>
        </ul>
        <div class="mt-4 text-xs text-gray-500 space-y-1">
          <p>{publisher.shortName}</p>
          <p>ИНН {publisher.inn} · КПП {publisher.kpp} · ОГРН {publisher.ogrn}</p>
          <p>{publisher.address}</p>
          <p><a href={`tel:${publisher.phone.replace(/[\s()-]/g, '')}`} class="hover:text-gray-300">{publisher.phone}</a></p>
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gray-700 pt-6 text-xs text-gray-500">
      <p>© {year} {publisher.shortName}. Все права защищены.</p>
      <p>
        Главный редактор: {publisher.editorInChief} ·
        <a href={`mailto:${publisher.email}`} class="hover:text-gray-300">{publisher.email}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .font-headline {
    font-family: var(--font-serif);
  }
</style>
