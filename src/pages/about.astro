---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import rssSources from '../../rss-sources.json';
import { site } from '../lib/site';

const base = import.meta.env.BASE_URL;
---

<Layout title={`О проекте — ${site.name}`} description="Информация о портале Гражданин, источниках контента и редакции">
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="mx-auto max-w-7xl px-4 py-6">
    <Breadcrumbs items={[{ label: 'Главная', href: base }, { label: 'О проекте' }]} />

    <div class="grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white border border-gray-200 p-6 sm:p-8">
          <h1 class="font-headline text-3xl font-bold text-gray-900 mb-4">О проекте «{site.name}»</h1>
          <div class="prose-citizen text-gray-700 space-y-4">
            <p>
              «{site.name}» — независимый новостной портал о пенсиях, налогах, пособиях
              и мерах социальной поддержки для граждан России.
              Издание operated by {site.publisher.shortName}.
            </p>
            <p>
              Мы агрегируем материалы открытых RSS-лент проверенных СМИ и НКО,
              готовим краткие редакционные пересказы и направляем читателей к первоисточникам
              для получения полной информации.
            </p>
          </div>
        </div>

        <div class="bg-white border border-gray-200 p-6 sm:p-8">
          <h2 class="font-headline text-xl font-bold text-gray-900 mb-4">Правовые основания цитирования</h2>
          <div class="prose-citizen text-gray-700 space-y-3 text-base">
            <p>Каждая публикация содержит:</p>
            <ul class="list-disc pl-6 space-y-1">
              <li>прямую гиперссылку на оригинальный материал;</li>
              <li>название источника и автора (если указан в оригинале);</li>
              <li>краткий пересказ объёмом не более 30% от оригинала;</li>
              <li>информационную цель — ознакомление с социальными инициативами.</li>
            </ul>
            <p>
              Цитирование осуществляется в соответствии со <strong>статьёй 1274 Гражданского кодекса РФ</strong>.
            </p>
          </div>
        </div>

        <div class="bg-white border border-gray-200 p-6 sm:p-8">
          <h2 class="font-headline text-xl font-bold text-gray-900 mb-4">RSS-источники</h2>
          <ul class="divide-y divide-gray-100">
            {rssSources.map((source) => (
              <li class="py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <div>
                  <span class="font-medium text-gray-800">{source.name}</span>
                  <span class="ml-2 inline-block bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                    {source.category}
                  </span>
                </div>
                <a
                  href={source.url.replace('/feed/', '/').replace('/feed', '/')}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[#c41e3a] hover:underline shrink-0"
                >
                  Сайт источника ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="bg-white border border-gray-200 p-6">
          <h2 class="font-headline text-lg font-bold text-gray-900 mb-4">Редакция</h2>
          <dl class="text-sm space-y-3">
            <div>
              <dt class="text-gray-500 text-xs uppercase tracking-wider">Издание</dt>
              <dd class="text-gray-800">{site.publisher.shortName}</dd>
            </div>
            <div>
              <dt class="text-gray-500 text-xs uppercase tracking-wider">Главный редактор</dt>
              <dd class="text-gray-800">{site.publisher.editorInChief}</dd>
            </div>
            <div>
              <dt class="text-gray-500 text-xs uppercase tracking-wider">Контакты</dt>
              <dd>
                <a href={`${base}contacts/`} class="text-[#c41e3a] hover:underline">Все контакты →</a>
              </dd>
            </div>
          </dl>
        </div>

        <div class="bg-gray-50 border border-gray-200 p-6 text-sm">
          <h3 class="font-bold text-gray-800 mb-2">Документы</h3>
          <ul class="space-y-2">
            <li><a href={`${base}editorial/`} class="text-[#c41e3a] hover:underline">Редакционная политика</a></li>
            <li><a href={`${base}privacy/`} class="text-[#c41e3a] hover:underline">Политика конфиденциальности</a></li>
            <li><a href={`${base}terms/`} class="text-[#c41e3a] hover:underline">Пользовательское соглашение</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .font-headline {
    font-family: var(--font-serif);
  }
</style>
