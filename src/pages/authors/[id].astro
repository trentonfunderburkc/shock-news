---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import StoryCard from '../../components/StoryCard.astro';
import { authors } from '../../lib/authors';
import { getCollection } from 'astro:content';
import { site } from '../../lib/site';

export async function getStaticPaths() {
  return authors.map((author) => ({
    params: { id: String(author.id) },
  }));
}

const { id } = Astro.params;
const author = authors.find((a) => a.id === Number(id));
if (!author) return Astro.redirect('/');

const base = import.meta.env.BASE_URL;
const allStories = await getCollection('stories');
const authorStories = allStories
  .filter((s) => s.data.authorId === author.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={`${author.name} — ${site.name}`} description={author.bio}>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="mx-auto max-w-7xl px-4 py-6">
    <Breadcrumbs
      items={[
        { label: 'Главная', href: base },
        { label: 'Авторы', href: `${base}authors/` },
        { label: author.name },
      ]}
    />

    <div class="bg-white border border-gray-200 p-6 sm:p-8 mb-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img
          src={`${base}${author.avatar.replace(/^\//, '')}`}
          alt={author.name}
          width="140"
          height="140"
          class="h-36 w-36 rounded-full object-cover shrink-0"
        />
        <div>
          <h1 class="font-headline text-3xl font-bold text-gray-900">{author.name}</h1>
          <p class="text-[#c41e3a] font-medium mt-1">{author.role}</p>
          <p class="text-gray-600 leading-relaxed mt-3 max-w-2xl">{author.bio}</p>
          <p class="mt-4 text-sm text-gray-400">{authorStories.length} опубликованных материалов</p>
        </div>
      </div>
    </div>

    <h2 class="font-headline text-xl font-bold text-gray-900 mb-6 pb-2 border-b-2 border-[#c41e3a]">
      Материалы автора
    </h2>
    {authorStories.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {authorStories.map((story) => (
          <StoryCard story={story} />
        ))}
      </div>
    ) : (
      <p class="text-gray-500 bg-white border border-gray-200 p-8 text-center">
        У этого автора пока нет опубликованных материалов.
      </p>
    )}
  </div>
</Layout>

<style>
  .font-headline {
    font-family: var(--font-serif);
  }
</style>
